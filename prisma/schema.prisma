generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model tenant {
  id               String         @id
  domain           String
  name             String
  active           Boolean
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @db.Timestamptz(6)
  industry         Industry
  primary_use_case PrimaryUseCase
  timezone         String
  calls            calls[]
  users            user[]
}

model calls {
  call_id        Int      @id @default(autoincrement())
  tenant_id      Int
  agent_id       Int?
  source         String
  recording_path String   @default("")
  status         String
  creator_id     Int      @default(-1)
  retry_count    Int      @default(0)
  error_message  String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  tenant         tenant?  @relation(fields: [tenantId], references: [id])
  tenantId       String?
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @db.Timestamptz(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model session {
  id        String   @id
  expiresAt DateTime @db.Timestamptz(6)
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model user {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified Boolean
  image         String?
  tenantId      String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @db.Timestamptz(6)
  role          UserRole  @default(admin)
  account       account[]
  session       session[]
  tenant        tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model verification {
  id         String   @id
  identifier String   @unique
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @db.Timestamptz(6)
}

model pendingOnboarding {
  id               String   @id @default(uuid())
  email            String   @unique
  organizationName String?
  primaryUseCase   String?
  timezone         String?
  industry         String?
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  expiresAt        DateTime @db.Timestamptz(6)
}

enum UserRole {
  admin
  supervisor
  agent
}

enum CallSource {
  google_meet
  manual
  teams
  exotel
}

enum CallStatus {
  pending
  processing
  retry
  completed
}

enum PrimaryUseCase {
  sales
  customer_support
  operational_calls
  all_of_the_above
}

enum Industry {
  technology_software
  e_commerce_retail
  finance
  healthcare
  education
  real_estate
  telecommunication
  manufacturing
  professional_services
  others
}
